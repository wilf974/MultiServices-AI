# vhost serveur de memoire central (mem.example.com)
#
# IMPORTANT - architecture de ce VPS : un bloc `stream` ecoute le 443 PUBLIC et route par SNI
# vers les vhosts http en `listen 8443 ssl proxy_protocol` (set_real_ip_from 127.0.0.1 +
# real_ip_header proxy_protocol sont GLOBAUX dans nginx.conf, donc $remote_addr = vraie IP client).
# => un vhost en `listen 443 ssl` n'est JAMAIS servi publiquement (cert par defaut -> curl exit 60).
# Calque donc le pattern des autres sites : 8443 ssl proxy_protocol.
#
# Le token long impose `map_hash_bucket_size` >= 128. Remplacer __MEM_READ_TOKEN__ au deploiement.

map_hash_bucket_size 128;
map $http_authorization $mem_ok { default 0; "Bearer __MEM_READ_TOKEN__" 1; }
limit_req_zone $binary_remote_addr zone=mem:10m rate=30r/m;

server {
    server_name mem.example.com;
    listen 8443 ssl proxy_protocol;

    ssl_certificate     /etc/letsencrypt/live/mem.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mem.example.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # mTLS pour l'ingest (CA dediee). 'optional' : /mcp reste en bearer, /ingest exige le cert.
    ssl_client_certificate /etc/nginx/mtls/mem/ca.crt;
    ssl_verify_client optional;

    # Allowlist IP. Depuis le LAN du VPS, le hairpin NAT fait voir la passerelle (<GW_LAN>).
    allow <IP_PUBLIQUE_MAISON>;     # IP publique
    allow <IP_PUBLIQUE_BUREAU>;   # bureau
    allow <GW_LAN>;    # passerelle LAN maison (hairpin NAT)
    deny all;

    access_log /var/log/nginx/mem.access.log;
    error_log  /var/log/nginx/mem.error.log;

    location /mcp {
        if ($mem_ok = 0) { return 401; }
        limit_req zone=mem burst=10 nodelay;
        proxy_pass http://127.0.0.1:8302;
        proxy_http_version 1.1;
        proxy_set_header Host $host;          # le serveur MCP doit allowlister ce Host (MULTISERVICE_HTTP_ALLOWED_HOSTS)
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;                  # streamable-http / SSE
        proxy_read_timeout 1h;
    }

    location /ingest {
        if ($ssl_client_verify != SUCCESS) { return 403; }
        limit_req zone=mem burst=10 nodelay;
        proxy_pass http://127.0.0.1:8303;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Client-CN $ssl_client_s_dn_cn;   # identite imposee au service
    }

    location / { return 404; }
}

# Redirection 80 -> 443 (+ challenge HTTP-01 de certbot).
server {
    if ($host = mem.example.com) { return 301 https://$host$request_uri; }
    listen 80;
    server_name mem.example.com;
    return 404;
}
